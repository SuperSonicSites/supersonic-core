:heading {\"level\":3} -->\n\t\t\t\t<h3 class=\"wp-block-heading\">2-hour emergency response</h3>\n\t\t\t\t<!-- /wp:heading -->\n\t\t\t\t<!-- wp:paragraph {\"textColor\":\"contrast-subtle\"} -->\n\t\t\t\t<p class=\"has-contrast-subtle-color has-text-color\">A technician is dispatched within two hours for plan customers, day or night.</p>\n\t\t\t\t<!-- /wp:paragraph -->\n\t\t\t</div>\n\t\t\t<!-- /wp:group -->\n\t\t</div>\n\t\t<!-- /wp:column -->\n\t\t<!-- wp:column -->\n\t\t<div class=\"wp-block-column\">\n\t\t\t<!-- wp:group {\"textColor\":\"contrast\",\"backgroundColor\":\"base\",\"style\":{\"border\":{\"radius\":\"var(--wp--custom--radius--medium)\"},\"shadow\":\"var:preset|shadow|soft\",\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|l\",\"right\":\"var:preset|spacing|l\",\"bottom\":\"var:preset|spacing|l\",\"left\":\"var:preset|spacing|l\"}}}} -->\n\t\t\t<div class=\"wp-block-group has-contrast-color has-base-background-color has-text-color has-background\" style=\"border-radius:var(--wp--custom--radius--medium);padding-top:var(--wp--preset--spacing--l);padding-right:var(--wp--preset--spacing--l);padding-bottom:var(--wp--preset--spacing--l);padding-left:var(--wp--preset--spacing--l);box-shadow:var(--wp--preset--shadow--soft)\">\n\t\t\t\t<!-- wp:heading {\"level\":3} -->\n\t\t\t\t<h3 class=\"wp-block-heading\">Licensed, insured techs</h3>\n\t\t\t\t<!-- /wp:heading -->\n\t\t\t\t<!-- wp:paragraph {\"textColor\":\"contrast-subtle\"} -->\n\t\t\t\t<p class=\"has-contrast-subtle-color has-text-color\">Every visit is performed by a certified technician with documented compliance.</p>\n\t\t\t\t<!-- /wp:paragraph -->\n\t\t\t</div>\n\t\t\t<!-- /wp:group -->\n\t\t</div>\n\t\t<!-- /wp:column -->\n\t\t<!-- wp:column -->\n\t\t<div class=\"wp-block-column\">\n\t\t\t<!-- wp:group {\"textColor\":\"contrast\",\"backgroundColor\":\"base\",\"style\":{\"border\":{\"radius\":\"var(--wp--custom--radius--medium)\"},\"shadow\":\"var:preset|shadow|soft\",\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|l\",\"right\":\"var:preset|spacing|l\",\"bottom\":\"var:preset|spacing|l\",\"left\":\"var:preset|spacing|l\"}}}} -->\n\t\t\t<div class=\"wp-block-group has-contrast-color has-base-background-color has-text-color has-background\" style=\"border-radius:var(--wp--custom--radius--medium);padding-top:var(--wp--preset--spacing--l);padding-right:var(--wp--preset--spacing--l);padding-bottom:var(--wp--preset--spacing--l);padding-left:var(--wp--preset--spacing--l);box-shadow:var(--wp--preset--shadow--soft)\">\n\t\t\t\t<!-- wp:heading {\"level\":3} -->\n\t\t\t\t<h3 class=\"wp-block-heading\">One transparent invoice</h3>\n\t\t\t\t<!-- /wp:heading -->\n\t\t\t\t<!-- wp:paragraph {\"textColor\":\"contrast-subtle\"} -->\n\t\t\t\t<p class=\"has-contrast-subtle-color has-text-color\">Flat monthly pricing with itemized visits — no per-call surprises.</p>\n\t\t\t\t<!-- /wp:paragraph -->\n\t\t\t</div>\n\t\t\t<!-- /wp:group -->\n\t\t</div>\n\t\t<!-- /wp:column -->\n\t</div>\n\t<!-- /wp:columns -->\n</div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"Section: Testimonial\"},\"align\":\"full\",\"backgroundColor\":\"contrast\",\"textColor\":\"base\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|section-medium\",\"bottom\":\"var:preset|spacing|section-medium\"}}},\"layout\":{\"type\":\"constrained\",\"contentSize\":\"760px\"}} -->\n<div class=\"wp-block-group alignfull has-base-color has-contrast-background-color has-text-color has-background\" style=\"padding-top:var(--wp--preset--spacing--section-medium);padding-bottom:var(--wp--preset--spacing--section-medium)\">\n\t<!-- wp:image {\"width\":\"96px\",\"height\":\"96px\",\"className\":\"is-style-rounded\"} -->\n\t<figure class=\"wp-block-image is-resized is-style-rounded\"><img src=\"https://placehold.co/96x96/111111/ffffff?text=DM\" alt=\"Portrait of facilities manager Dana M.\" width=\"96\" height=\"96\"/></figure>\n\t<!-- /wp:image -->\n\t<!-- wp:quote -->\n\t<blockquote class=\"wp-block-quote\">\n\t\t<!-- wp:paragraph {\"fontSize\":\"large\"} -->\n\t\t<p class=\"has-large-font-size\">They caught a failing compressor weeks before it would have shut down our data floor. We have not had an unplanned outage since.</p>\n\t\t<!-- /wp:paragraph -->\n\t\t<cite>Dana M., Facilities Manager</cite>\n\t</blockquote>\n\t<!-- /wp:quote -->\n</div>\n<!-- /wp:group -->\n\n<!-- wp:group {\"metadata\":{\"name\":\"Section: Pricing Cards\"},\"align\":\"full\",\"backgroundColor\":\"surface\",\"style\":{\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|section-medium\",\"bottom\":\"var:preset|spacing|section-medium\"}}},\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group alignfull has-surface-background-color has-background\" style=\"padding-top:var(--wp--preset--spacing--section-medium);padding-bottom:var(--wp--preset--spacing--section-medium)\">\n\t<!-- wp:group {\"layout\":{\"type\":\"constrained\",\"contentSize\":\"760px\"}} -->\n\t<div class=\"wp-block-group\">\n\t\t<!-- wp:heading {\"textAlign\":\"center\",\"fontSize\":\"heading-2\"} -->\n\t\t<h2 class=\"wp-block-heading has-text-align-center has-heading-2-font-size\">Maintenance plans</h2>\n\t\t<!-- /wp:heading -->\n\t</div>\n\t<!-- /wp:group -->\n\t<!-- wp:columns {\"style\":{\"spacing\":{\"blockGap\":{\"top\":\"var:preset|spacing|m\",\"left\":\"var:preset|spacing|m\"}}}} -->\n\t<div class=\"wp-block-columns\">\n\t\t<!-- wp:column -->\n\t\t<div class=\"wp-block-column\">\n\t\t\t<!-- wp:group {\"textColor\":\"contrast\",\"backgroundColor\":\"base\",\"style\":{\"border\":{\"radius\":\"var(--wp--custom--radius--medium)\"},\"spacing\":{\"padding\":{\"top\":\"var:preset|spacing|l\",\"right\":\"var:preset|spacing|l\",\"bottom\":\"var:preset|spacing|l\",\"left\":\"var:preset|spacing|l\"}}}} -->\n\t\t\t<div class=\"wp-block-group has-contrast-color has-base-background-color has-text-color has-background\" style=\"border-radius:var(--wp--custom--radius--medium);padding-top:var(--wp