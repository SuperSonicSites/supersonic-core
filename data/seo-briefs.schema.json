{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/SuperSonicSites/supersonic-core/data/seo-briefs.schema.json",
  "title": "Supersonic SEO Briefs",
  "description": "Per-page SEO content briefs produced by the seo-strategist skill during Init. The seo-strategist owns the authoritative SEO metadata here (titles, meta descriptions, slugs, schema plan, keyword map, heading outline, internal links). layout-architect realizes structure, the writer fills body copy only, and the plugin/Rank Math emits the JSON-LD. Generate data/seo-briefs.json from this schema in a cloned site repo; data/seo-briefs.example.json is a worked example.",
  "type": "object",
  "additionalProperties": false,
  "required": ["site", "handoff", "briefs"],
  "properties": {
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["niche", "geography", "competitors"],
      "properties": {
        "niche": { "type": "string" },
        "geography": { "type": "string" },
        "competitors": { "type": "array", "items": { "type": "string" } },
        "dataSource": { "type": "string", "description": "e.g. Ubersuggest MCP" },
        "notes": { "type": "string" }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "description": "Restates the ownership boundary so downstream agents do not re-decide SEO metadata. writerEditable must never include seo_title, meta_description, or schema.",
      "required": ["strategistOwns", "writerEditable", "structureBy", "schemaEmittedBy"],
      "properties": {
        "strategistOwns": { "type": "array", "items": { "type": "string" } },
        "writerEditable": { "type": "array", "items": { "type": "string" } },
        "structureBy": { "type": "string" },
        "schemaEmittedBy": { "type": "string" }
      }
    },
    "briefs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "page_id",
          "page_title",
          "url_slug",
          "archetype",
          "search_intent",
          "primary_keyword",
          "secondary_keywords",
          "lsi_terms",
          "seo_title",
          "meta_description",
          "target_word_count",
          "outline",
          "internal_links",
          "schema"
        ],
        "properties": {
          "page_id": { "type": "string" },
          "page_title": { "type": "string" },
          "url_slug": {
            "type": "string",
            "description": "Lowercase, hyphen-separated path, <=5 words, mapped to the primary keyword. Root home page may be \"/\".",
            "pattern": "^/(?:[a-z0-9]+(?:-[a-z0-9]+)*(?:/[a-z0-9]+(?:-[a-z0-9]+)*)*)?/?$"
          },
          "archetype": {
            "type": "string",
            "description": "Page archetype from docs/layout-standard.md.",
            "enum": [
              "home",
              "service",
              "landing",
              "about",
              "contact",
              "pricing",
              "blog-article",
              "faq",
              "local-business"
            ]
          },
          "search_intent": {
            "type": "string",
            "enum": ["informational", "commercial", "transactional", "navigational"]
          },
          "primary_keyword": {
            "type": "object",
            "additionalProperties": false,
            "required": ["term", "volume", "seo_difficulty"],
            "properties": {
              "term": { "type": "string" },
              "volume": { "type": "integer", "minimum": 0 },
              "seo_difficulty": { "type": "integer", "minimum": 0, "maximum": 100 },
              "source": { "type": "string" }
            }
          },
          "secondary_keywords": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["term"],
              "properties": {
                "term": { "type": "string" },
                "volume": { "type": "integer", "minimum": 0 },
                "seo_difficulty": { "type": "integer", "minimum": 0, "maximum": 100 }
              }
            }
          },
          "lsi_terms": {
            "type": "array",
            "description": "3-5 latent-semantic terms woven into subheadings and copy.",
            "items": { "type": "string" }
          },
          "seo_title": { "type": "string", "minLength": 1, "maxLength": 60 },
          "meta_description": { "type": "string", "minLength": 1, "maxLength": 160 },
          "target_word_count": { "type": "integer", "minimum": 0 },
          "outline": {
            "type": "object",
            "additionalProperties": false,
            "required": ["h1", "sections"],
            "properties": {
              "h1": { "type": "string" },
              "sections": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["h2"],
                  "properties": {
                    "h2": { "type": "string" },
                    "h3": { "type": "array", "items": { "type": "string" } },
                    "talking_points": { "type": "array", "items": { "type": "string" } },
                    "lsi_focus": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          },
          "internal_links": {
            "type": "array",
            "description": "2-4 contextual links (hub pages may have more). target_slug should reference another brief or an existing page.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["target_slug", "anchor_text"],
              "properties": {
                "target_slug": { "type": "string" },
                "anchor_text": { "type": "string" },
                "rationale": { "type": "string" }
              }
            }
          },
          "schema": {
            "type": "object",
            "additionalProperties": false,
            "description": "Structured-data PLAN only. emitted_by records who emits the JSON-LD; it is never this agent.",
            "required": ["type", "emitted_by"],
            "properties": {
              "type": { "type": "string" },
              "additional_types": { "type": "array", "items": { "type": "string" } },
              "required_fields": { "type": "object" },
              "emitted_by": { "type": "string", "enum": ["plugin", "rank-math", "seo-layer"] },
              "notes": { "type": "string" }
            }
          },
          "competitor_refs": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["url"],
              "properties": {
                "url": { "type": "string" },
                "domain": { "type": "string" },
                "gap": { "type": "string" }
              }
            }
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
