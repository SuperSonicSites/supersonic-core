{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1440px"
    },
    "color": {
      "defaultPalette": false,
      "palette": [
        {
          "color": "#ffffff",
          "name": "Base",
          "slug": "base"
        },
        {
          "color": "#111111",
          "name": "Contrast",
          "slug": "contrast"
        },
        {
          "color": "#f5f5f5",
          "name": "Muted",
          "slug": "muted"
        },
        {
          "color": "#1f6feb",
          "name": "Accent",
          "slug": "accent"
        }
      ]
    },
    "spacing": {
      "spacingSizes": [
        {
          "name": "2XS",
          "size": "0.5rem",
          "slug": "2-xs"
        },
        {
          "name": "XS",
          "size": "0.75rem",
          "slug": "xs"
        },
        {
          "name": "S",
          "size": "1rem",
          "slug": "s"
        },
        {
          "name": "M",
          "size": "1.5rem",
          "slug": "m"
        },
        {
          "name": "L",
          "size": "2rem",
          "slug": "l"
        },
        {
          "name": "XL",
          "size": "3.5rem",
          "slug": "xl"
        },
        {
          "name": "2XL",
          "size": "5rem",
          "slug": "2-xl"
        }
      ],
      "units": [
        "px",
        "rem",
        "%",
        "vw",
        "vh"
      ]
    },
    "typography": {
      "fluid": false,
      "fontSizes": [
        {
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "name": "Body",
          "size": "1rem",
          "slug": "body"
        },
        {
          "name": "Large",
          "size": "1.125rem",
          "slug": "large"
        },
        {
          "name": "Heading 3",
          "size": "1.5rem",
          "slug": "heading-3"
        },
        {
          "name": "Heading 2",
          "size": "2.25rem",
          "slug": "heading-2"
        },
        {
          "name": "Heading 1",
          "size": "3.25rem",
          "slug": "heading-1"
        }
      ]
    }
  },
  "styles": {
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "lineHeight": "1.15"
        }
      }
    }
  }
}

