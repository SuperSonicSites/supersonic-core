{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Bold Industrial",
	"description": "Heavy type, sharp corners, tight leading. For trades, security, manufacturing, logistics — brands that sell strength and competence.",
	"settings": {
		"typography": {
			"fontSizes": [
				{ "name": "Small", "size": "0.875rem", "slug": "small", "fluid": false },
				{ "name": "Body", "size": "1.125rem", "slug": "body", "fluid": { "min": "1rem", "max": "1.125rem" } },
				{ "name": "Large", "size": "1.375rem", "slug": "large", "fluid": { "min": "1.125rem", "max": "1.375rem" } },
				{ "name": "Heading 3", "size": "1.875rem", "slug": "heading-3", "fluid": { "min": "1.5rem", "max": "1.875rem" } },
				{ "name": "Heading 2", "size": "3.25rem", "slug": "heading-2", "fluid": { "min": "2.125rem", "max": "3.25rem" } },
				{ "name": "Heading 1", "size": "4.5rem", "slug": "heading-1", "fluid": { "min": "2.75rem", "max": "4.5rem" } },
				{ "name": "Display", "size": "6rem", "slug": "display", "fluid": { "min": "3.25rem", "max": "6rem" } }
			]
		},
		"custom": {
			"radius": {
				"none": "0",
				"small": "2px",
				"medium": "4px",
				"large": "8px",
				"pill": "999px"
			}
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "800",
					"letterSpacing": "-0.01em",
					"lineHeight": "1.05"
				}
			},
			"h1": {
				"typography": {
					"lineHeight": "1.0"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "800",
					"letterSpacing": "0.02em",
					"textTransform": "uppercase"
				}
			}
		}
	}
}
