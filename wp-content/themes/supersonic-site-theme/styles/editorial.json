{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"version": 3,
	"title": "Editorial",
	"description": "Serif display, lighter weights, generous leading. For professional services, hospitality, heritage brands — confidence through restraint.",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"fontFamily": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
					"name": "Body (Inter)",
					"slug": "inter"
				},
				{
					"fontFamily": "Georgia, \"Iowan Old Style\", \"Palatino Linotype\", \"Times New Roman\", serif",
					"name": "Heading (Serif)",
					"slug": "montserrat"
				}
			],
			"fontSizes": [
				{ "name": "Small", "size": "0.9375rem", "slug": "small", "fluid": false },
				{ "name": "Body", "size": "1.1875rem", "slug": "body", "fluid": { "min": "1.0625rem", "max": "1.1875rem" } },
				{ "name": "Large", "size": "1.4375rem", "slug": "large", "fluid": { "min": "1.1875rem", "max": "1.4375rem" } },
				{ "name": "Heading 3", "size": "1.9375rem", "slug": "heading-3", "fluid": { "min": "1.5rem", "max": "1.9375rem" } },
				{ "name": "Heading 2", "size": "2.875rem", "slug": "heading-2", "fluid": { "min": "2rem", "max": "2.875rem" } },
				{ "name": "Heading 1", "size": "4.25rem", "slug": "heading-1", "fluid": { "min": "2.625rem", "max": "4.25rem" } },
				{ "name": "Display", "size": "5.25rem", "slug": "display", "fluid": { "min": "3rem", "max": "5.25rem" } }
			]
		},
		"custom": {
			"radius": {
				"none": "0",
				"small": "3px",
				"medium": "6px",
				"large": "12px",
				"pill": "999px"
			}
		}
	},
	"styles": {
		"elements": {
			"heading": {
				"typography": {
					"fontWeight": "400",
					"letterSpacing": "-0.005em",
					"lineHeight": "1.18"
				}
			},
			"h1": {
				"typography": {
					"lineHeight": "1.1"
				}
			},
			"button": {
				"typography": {
					"fontWeight": "600",
					"letterSpacing": "0.01em"
				}
			}
		}
	}
}
