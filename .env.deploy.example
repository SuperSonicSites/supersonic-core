# Supersonic Core DEPLOY credentials example (HUMAN-ONLY)
#
# Copy to `.env.deploy` (git-ignored) and fill in locally if you do manual
# SSH/production work. The agent and the scripts in tools/ must never read this
# file; it exists so deploy/production secrets stay out of the agent-readable
# `.env`.
#
# These are NOT needed for the automated theme deploy (that path uses only the
# staging REST keys in `.env` plus GitHub Actions secrets).

WP_PRODUCTION_URL=
HOSTINGER_SSH_HOST=
HOSTINGER_SSH_USER=
HOSTINGER_STAGING_PATH=
HOSTINGER_PRODUCTION_PATH=
