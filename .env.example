# Supersonic Core environment example
#
# Copy values into your local `.env` when needed.
# Do not commit real credentials. `.env` is git-ignored.
#
# Claude and the tools in tools/ only read these three staging REST keys.
# Production deployment is handled manually by the site owner.

WP_STAGING_URL=
WP_REST_USER=
WP_REST_APP_PASSWORD=

# --- Deploy / SSH credentials are HUMAN-ONLY ---
# They live in a separate, git-ignored `.env.deploy` so the agent and tools/
# never read them. See `.env.deploy.example`. Do NOT add SSH or production
# values to this file.
